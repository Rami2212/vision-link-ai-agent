# vision-link-ai-agent — Environment Variables
# -----------------------------------------------
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub. It is in .gitignore.
#
# GitHub Actions: add these as repository secrets at
# Settings → Secrets and variables → Actions

# ── Hugging Face ──────────────────────────────────
# Required to pull Meta Llama-3-8B-Instruct and MedLlama
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# ── App config ────────────────────────────────────
# Set to 'false' during dev to skip the evolution engine
EVOLUTION_ENABLED=true
MAX_RETRIES=3
LOG_LEVEL=INFO
